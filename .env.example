# Скопируйте этот файл в .env и заполните значения

# ======================================================
# OpenRouter (бесплатно, регистрация: https://openrouter.ai)
# Ключ: https://openrouter.ai/keys
# ======================================================
OPENAI_API_KEY=sk-or-v1-...ваш_ключ...
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Рекомендуемые бесплатные модели (--model):
#   mistralai/mistral-small-3.1-24b-instruct:free  ← по умолчанию (128k контекст)
#   meta-llama/llama-3.3-70b-instruct:free         (часто перегружен)
#   google/gemma-3-27b-it:free                     (131k контекст)
#   nousresearch/hermes-3-llama-3.1-405b:free      (очень сильная, 131k)

# ======================================================
# OpenAI напрямую (платно)
# ======================================================
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=   (не задавать)

# (MVP-2) TeamCity — URL и токен для автоматического сбора отчётов
# TEAMCITY_URL=https://your-teamcity-server
# TEAMCITY_TOKEN=your_token_here
# TEAMCITY_BUILD_TYPE_ID=YourProject_RunTests

# (MVP-2) Путь к репозиторию с автотестами для RAG-индексации
# CODEBASE_PATH=C:/Projects/YourAutotests
